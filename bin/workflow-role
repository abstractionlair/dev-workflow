#!/bin/bash
# Launch an interactive workflow role session in the appropriate harness.
#
# Usage:
#   workflow-role <role> [project-dir] [artifact-path] [-- harness-args...]
#   workflow-role macro-reviewer ~/projects/work-graph docs/VISION.md
#   workflow-role spec-writer ~/projects/work-graph
#   workflow-role micro-reviewer work-graph src/engine.py
#   HARNESS=gemini workflow-role macro-reviewer ~/projects/work-graph docs/VISION.md
#
# Roles: planner, spec-writer, macro-reviewer, micro-reviewer,
#        skeleton-writer, test-writer, implementer
#
# Harness selection:
#   - Most roles: read from model-config.json
#   - macro-reviewer: depends on artifact type (gemini for docs, opencode for code)
#   - micro-reviewer: always opencode (open models)
#   - Override any role: HARNESS=claude|gemini|opencode

set -e

DEPLOY_DIR="$HOME/deploy/dev-workflow"
CONFIG="$DEPLOY_DIR/model-config.json"

if [ -z "$1" ]; then
    echo "Usage: workflow-role <role> [project-dir] [artifact-path] [-- harness-args...]"
    echo ""
    echo "Roles:"
    for f in "$DEPLOY_DIR"/roles/*.md; do
        basename "$f" .md
    done
    echo ""
    echo "Override harness: HARNESS=claude|gemini|opencode workflow-role <role> ..."
    exit 1
fi

ROLE="$1"
shift

# Validate role exists
if [ ! -f "$DEPLOY_DIR/roles/$ROLE.md" ]; then
    echo "Error: unknown role '$ROLE'"
    echo "Available roles:"
    for f in "$DEPLOY_DIR"/roles/*.md; do
        echo "  $(basename "$f" .md)"
    done
    exit 1
fi

# Parse project directory
PROJECT_DIR=""
if [ $# -gt 0 ] && [[ "$1" != -* ]] && [[ "$1" != "--" ]]; then
    if [ -d "$1" ]; then
        PROJECT_DIR="$1"
        shift
    elif [ -d "$HOME/projects/$1" ]; then
        PROJECT_DIR="$HOME/projects/$1"
        shift
    else
        echo "Error: project directory not found: $1"
        exit 1
    fi
fi

if [ -z "$PROJECT_DIR" ]; then
    PROJECT_DIR="$(pwd)"
fi

# Parse optional artifact path (relative to project)
ARTIFACT=""
if [ $# -gt 0 ] && [[ "$1" != -* ]] && [[ "$1" != "--" ]]; then
    ARTIFACT="$1"
    shift
fi

# Skip -- separator if present
if [ "${1:-}" = "--" ]; then
    shift
fi

# Classify artifact as "doc" or "code" for reviewer harness selection
artifact_class() {
    local path="$1"
    case "$path" in
        docs/VISION*|docs/SCOPE*|docs/ROADMAP*|specs/proposed/*|specs/todo/*)
            echo "doc" ;;
        *)
            echo "code" ;;
    esac
}

# Determine harness: explicit HARNESS env var > artifact-aware config lookup
if [ -z "${HARNESS:-}" ] && [ -f "$CONFIG" ]; then
    if [ "$ROLE" = "macro-reviewer" ] && [ -n "$ARTIFACT" ]; then
        # Macro-reviewer harness depends on artifact type
        ACLASS=$(artifact_class "$ARTIFACT")
        if [ "$ACLASS" = "doc" ]; then
            HARNESS="gemini"
        else
            HARNESS="opencode"
        fi
    else
        # All other roles: read preferred tool from config
        TOOL=$(python3 -c "
import json
with open('$CONFIG') as f:
    cfg = json.load(f)
role_cfg = cfg.get('roles', {}).get('$ROLE', {})
print(role_cfg.get('tool', 'claude'))
" 2>/dev/null || echo "claude")

        case "$TOOL" in
            claude|gemini|opencode) HARNESS="$TOOL" ;;
            *) HARNESS="claude" ;;
        esac
    fi
fi

HARNESS="${HARNESS:-claude}"

# Determine schema references based on role and artifact
SCHEMA=""
case "$ROLE" in
    macro-reviewer|micro-reviewer)
        # Infer schema from artifact path
        if [[ "$ARTIFACT" == docs/VISION* ]]; then SCHEMA="vision"
        elif [[ "$ARTIFACT" == docs/SCOPE* ]]; then SCHEMA="scope"
        elif [[ "$ARTIFACT" == docs/ROADMAP* ]]; then SCHEMA="roadmap"
        elif [[ "$ARTIFACT" == specs/* ]]; then SCHEMA="spec"
        elif [[ "$ARTIFACT" == bugs/* ]]; then SCHEMA="bug-report"
        fi
        [ -n "$SCHEMA" ] && SCHEMA="$SCHEMA (artifact), review (output format)"
        ;;
    planner)
        if [[ "$ARTIFACT" == *VISION* ]]; then SCHEMA="vision"
        elif [[ "$ARTIFACT" == *SCOPE* ]]; then SCHEMA="scope"
        elif [[ "$ARTIFACT" == *ROADMAP* ]]; then SCHEMA="roadmap"
        fi
        ;;
    spec-writer) SCHEMA="spec" ;;
esac

# Build role-specific framing
ROLE_FRAMING=""
if [[ "$ROLE" == *reviewer* ]]; then
    # Infer review category for history path
    REVIEW_CATEGORY=""
    if [[ "$ARTIFACT" == docs/VISION* ]]; then REVIEW_CATEGORY="vision"
    elif [[ "$ARTIFACT" == docs/SCOPE* ]]; then REVIEW_CATEGORY="scope"
    elif [[ "$ARTIFACT" == docs/ROADMAP* ]]; then REVIEW_CATEGORY="roadmap"
    elif [[ "$ARTIFACT" == specs/* ]]; then REVIEW_CATEGORY="specs"
    elif [[ "$ARTIFACT" == bugs/* ]]; then REVIEW_CATEGORY="bugs"
    else REVIEW_CATEGORY="implementations"
    fi

    ROLE_FRAMING="
## Review expectations

Your honest assessment is valued. There is no penalty for pointing out problems — accurate feedback, including criticism, is genuinely helpful. At the same time, you don't need to force yourself to find faults. If something is good, say so. If something is wrong, describe it. Your authentic judgment is what matters.

If previous reviews exist, read them for context but form your own independent view. Agree or disagree based on your own reading of the artifact.

**Prior reviews:** Check \`reviews/$REVIEW_CATEGORY/\` for any existing reviews of this artifact.
**Structural non-compliance** (missing mandatory schema sections) is a P0 blocking issue, regardless of content quality."
fi

# Write active role assignment to project
mkdir -p "$PROJECT_DIR/.workflow"
cat > "$PROJECT_DIR/.workflow/active-role.md" << EOF
# Workflow Assignment

**Directive:** Perform the $ROLE task on the artifact below. Read the role file and preamble, then act — produce the output artifact directly.

**Role:** $ROLE
**Role file:** ~/deploy/dev-workflow/roles/$ROLE.md
$([ -n "$ARTIFACT" ] && echo "**Artifact:** $ARTIFACT")
$([ -n "$SCHEMA" ] && echo "**Schema:** ~/deploy/dev-workflow/schemas/ — $SCHEMA")
$ROLE_FRAMING
EOF

echo "Launching $ROLE in $HARNESS (project: $(basename "$PROJECT_DIR"))"
[ -n "$ARTIFACT" ] && echo "  Artifact: $ARTIFACT"
echo ""

# Build harness-specific flags and prep
HARNESS_FLAGS=()
case "$HARNESS" in
    gemini)
        # Gemini sandbox restricts to project dir — whitelist the deploy tree
        HARNESS_FLAGS+=(--include-directories "$HOME/deploy/dev-workflow")
        ;;
    opencode)
        # OpenCode snapshots the project dir — copy essential workflow files in
        CONTEXT_DIR="$PROJECT_DIR/.workflow/context"
        mkdir -p "$CONTEXT_DIR"
        cp "$DEPLOY_DIR/roles/$ROLE.md" "$CONTEXT_DIR/role.md"
        cp "$DEPLOY_DIR/preamble.md" "$CONTEXT_DIR/preamble.md"
        cp "$DEPLOY_DIR/ontology.md" "$CONTEXT_DIR/ontology.md"
        [ -n "$SCHEMA" ] && {
            # Copy referenced schemas (extract first word before any parenthetical)
            for s in $(echo "$SCHEMA" | tr ',' '\n' | sed 's/ (.*//' | tr -d ' '); do
                [ -f "$DEPLOY_DIR/schemas/$s.md" ] && cp "$DEPLOY_DIR/schemas/$s.md" "$CONTEXT_DIR/"
            done
        }
        # Update active-role.md to point to local copies
        sed -i 's|~/deploy/dev-workflow/roles/|.workflow/context/|' "$PROJECT_DIR/.workflow/active-role.md"
        sed -i 's|~/deploy/dev-workflow/|.workflow/context/|' "$PROJECT_DIR/.workflow/active-role.md"
        ;;
esac

# Launch via role script
export HARNESS
exec "$HOME/bin/role" workflow "$PROJECT_DIR" "${HARNESS_FLAGS[@]}" "$@"
