#!/bin/bash
# Launch an interactive workflow role session in the appropriate harness.
#
# Usage:
#   workflow-role <role> [project-dir] [artifact-path] [-- harness-args...]
#   workflow-role macro-reviewer ~/projects/work-graph docs/VISION.md
#   workflow-role spec-writer ~/projects/work-graph
#   workflow-role micro-reviewer work-graph src/engine.py
#   HARNESS=gemini workflow-role macro-reviewer ~/projects/work-graph docs/VISION.md
#
# Roles: planner, spec-writer, macro-reviewer, micro-reviewer,
#        skeleton-writer, test-writer, implementer
#
# Harness selection:
#   - Most roles: read from model-config.json
#   - macro-reviewer: depends on artifact type (gemini for docs, codex for code)
#   - micro-reviewer: always codex/gpt-5.4
#   - Override any role: HARNESS=claude|gemini|codex

set -e

DEPLOY_DIR="$HOME/deploy/dev-workflow"
CONFIG="$DEPLOY_DIR/model-config.json"

if [ -z "$1" ]; then
    echo "Usage: workflow-role <role> [project-dir] [artifact-path] [-- harness-args...]"
    echo ""
    echo "Roles:"
    for f in "$DEPLOY_DIR"/roles/*.md; do
        basename "$f" .md
    done
    echo ""
    echo "Override harness: HARNESS=claude|gemini|codex workflow-role <role> ..."
    exit 1
fi

ROLE="$1"
shift

# Validate role exists
if [ ! -f "$DEPLOY_DIR/roles/$ROLE.md" ]; then
    echo "Error: unknown role '$ROLE'"
    echo "Available roles:"
    for f in "$DEPLOY_DIR"/roles/*.md; do
        echo "  $(basename "$f" .md)"
    done
    exit 1
fi

# Parse project directory
PROJECT_DIR=""
if [ $# -gt 0 ] && [[ "$1" != -* ]] && [[ "$1" != "--" ]]; then
    if [ -d "$1" ]; then
        PROJECT_DIR="$1"
        shift
    elif [ -d "$HOME/projects/$1" ]; then
        PROJECT_DIR="$HOME/projects/$1"
        shift
    else
        echo "Error: project directory not found: $1"
        exit 1
    fi
fi

if [ -z "$PROJECT_DIR" ]; then
    PROJECT_DIR="$(pwd)"
fi

# Parse optional artifact path (relative to project)
ARTIFACT=""
if [ $# -gt 0 ] && [[ "$1" != -* ]] && [[ "$1" != "--" ]]; then
    ARTIFACT="$1"
    shift
fi

# Skip -- separator if present
if [ "${1:-}" = "--" ]; then
    shift
fi

# Classify artifact as "doc" or "code" for reviewer harness selection
artifact_class() {
    local path="$1"
    case "$path" in
        docs/VISION*|docs/SCOPE*|docs/ROADMAP*|specs/proposed/*|specs/todo/*)
            echo "doc" ;;
        *)
            echo "code" ;;
    esac
}

# Determine harness: explicit HARNESS env var > artifact-aware config lookup
if [ -z "${HARNESS:-}" ] && [ -f "$CONFIG" ]; then
    if [ "$ROLE" = "macro-reviewer" ] && [ -n "$ARTIFACT" ]; then
        # Macro-reviewer harness depends on artifact type
        ACLASS=$(artifact_class "$ARTIFACT")
        if [ "$ACLASS" = "doc" ]; then
            HARNESS="gemini"
        else
            HARNESS="codex"
        fi
    else
        # All other roles: read preferred tool from config
        TOOL=$(python3 -c "
import json
with open('$CONFIG') as f:
    cfg = json.load(f)
role_cfg = cfg.get('roles', {}).get('$ROLE', {})
print(role_cfg.get('tool', 'claude'))
" 2>/dev/null || echo "claude")

        case "$TOOL" in
            claude|gemini|codex) HARNESS="$TOOL" ;;
            *) HARNESS="claude" ;;
        esac
    fi
fi

HARNESS="${HARNESS:-claude}"

# Look up model-specific guidance
# Maps harness/model to a model family for guidance lookup
MODEL_FAMILY=""
case "$HARNESS" in
    gemini) MODEL_FAMILY="gemini" ;;
    codex) MODEL_FAMILY="gpt" ;;
    claude) MODEL_FAMILY="claude" ;;
esac

# Determine role category for guidance (reviewer, writer, etc.)
ROLE_CATEGORY=""
case "$ROLE" in
    macro-reviewer|micro-reviewer) ROLE_CATEGORY="reviewer" ;;
    planner|spec-writer) ROLE_CATEGORY="writer" ;;
    skeleton-writer|test-writer|implementer) ROLE_CATEGORY="builder" ;;
esac

# Load guidance file if one exists for this model+role combination
MODEL_GUIDANCE=""
GUIDANCE_FILE="$DEPLOY_DIR/guidance/${MODEL_FAMILY}-${ROLE_CATEGORY}.md"
if [ -f "$GUIDANCE_FILE" ]; then
    MODEL_GUIDANCE=$(cat "$GUIDANCE_FILE")
fi

# Determine schema references based on role and artifact
SCHEMA=""
case "$ROLE" in
    macro-reviewer|micro-reviewer)
        # Infer schema from artifact path
        if [[ "$ARTIFACT" == docs/VISION* ]]; then SCHEMA="vision"
        elif [[ "$ARTIFACT" == docs/SCOPE* ]]; then SCHEMA="scope"
        elif [[ "$ARTIFACT" == docs/ROADMAP* ]]; then SCHEMA="roadmap"
        elif [[ "$ARTIFACT" == specs/* ]]; then SCHEMA="spec"
        elif [[ "$ARTIFACT" == bugs/* ]]; then SCHEMA="bug-report"
        fi
        [ -n "$SCHEMA" ] && SCHEMA="$SCHEMA (artifact), review (output format)"
        ;;
    planner)
        if [[ "$ARTIFACT" == *VISION* ]]; then SCHEMA="vision"
        elif [[ "$ARTIFACT" == *SCOPE* ]]; then SCHEMA="scope"
        elif [[ "$ARTIFACT" == *ROADMAP* ]]; then SCHEMA="roadmap"
        fi
        ;;
    spec-writer) SCHEMA="spec" ;;
esac

# Build role-specific framing
ROLE_FRAMING=""
STAGE_CONTEXT=""
ARTIFACT_TYPE=""
if [[ "$ROLE" == *reviewer* ]]; then
    # Infer review category and artifact type for history path and evaluation criteria
    REVIEW_CATEGORY=""
    if [[ "$ARTIFACT" == docs/VISION* ]]; then
        REVIEW_CATEGORY="vision"; ARTIFACT_TYPE="Vision"
    elif [[ "$ARTIFACT" == docs/SCOPE* ]]; then
        REVIEW_CATEGORY="scope"; ARTIFACT_TYPE="Scope"
    elif [[ "$ARTIFACT" == docs/ROADMAP* ]]; then
        REVIEW_CATEGORY="roadmap"; ARTIFACT_TYPE="Roadmap"
    elif [[ "$ARTIFACT" == specs/* ]]; then
        REVIEW_CATEGORY="specs"; ARTIFACT_TYPE="Spec"
    elif [[ "$ARTIFACT" == bugs/* ]]; then
        REVIEW_CATEGORY="bugs"; ARTIFACT_TYPE="Bug Fix"
    else
        # Code artifact: detect workflow stage from spec location
        if ls "$PROJECT_DIR"/specs/todo/*.md &>/dev/null; then
            ARTIFACT_TYPE="Skeleton"
            REVIEW_CATEGORY="skeleton"
            STAGE_CONTEXT="This is a **skeleton review**. The spec is in \`specs/todo/\`. Skeleton code should contain interface definitions with \`NotImplementedError\` stubs — not working implementations. Evaluate against the **Skeleton** criteria in your role instructions."
        elif [[ "${ARTIFACT:-}" == tests/* ]] && ls "$PROJECT_DIR"/specs/doing/*.md &>/dev/null; then
            ARTIFACT_TYPE="Tests"
            REVIEW_CATEGORY="tests"
            STAGE_CONTEXT="This is a **test review** (RED phase). The spec is in \`specs/doing/\`. Tests should exist and currently FAIL against skeleton stubs. Evaluate against the **Tests** criteria in your role instructions."
        elif ls "$PROJECT_DIR"/specs/doing/*.md &>/dev/null; then
            ARTIFACT_TYPE="Implementation"
            REVIEW_CATEGORY="implementations"
            STAGE_CONTEXT="This is an **implementation review** (GREEN phase). The spec is in \`specs/doing/\`. All tests should PASS. Evaluate against the **Implementation** criteria in your role instructions."
        else
            ARTIFACT_TYPE="Code"
            REVIEW_CATEGORY="code"
        fi
    fi

    # Build review framing: stage context + model guidance (or default) + prior reviews
    DEFAULT_GUIDANCE="## Review expectations

Your honest assessment is valued. There is no penalty for pointing out problems — accurate feedback, including criticism, is genuinely helpful. At the same time, you don't need to force yourself to find faults. If something is good, say so. If something is wrong, describe it. Your authentic judgment is what matters.

Overlooking a real problem is as unhelpful as inventing a false one. Both undermine trust in the review process."

    ROLE_FRAMING="
$([ -n "$STAGE_CONTEXT" ] && echo "## Review Stage

$STAGE_CONTEXT
")
$([ -n "$MODEL_GUIDANCE" ] && echo "$MODEL_GUIDANCE" || echo "$DEFAULT_GUIDANCE")

If previous reviews exist, read them for context but form your own independent view. Agree or disagree based on your own reading of the artifact.

**Prior reviews:** Check \`reviews/$REVIEW_CATEGORY/\` for any existing reviews of this artifact.
**Structural non-compliance** (missing mandatory schema sections) is a P0 blocking issue, regardless of content quality."
fi

# Write active role assignment to project
mkdir -p "$PROJECT_DIR/.workflow"
cat > "$PROJECT_DIR/.workflow/active-role.md" << EOF
# Workflow Assignment

**Directive:** Perform the $ROLE task on the artifact below. Read the role file and preamble, then act — produce the output artifact directly.

**Role:** $ROLE
**Role file:** ~/deploy/dev-workflow/roles/$ROLE.md
$([ -n "$ARTIFACT_TYPE" ] && echo "**Artifact type:** $ARTIFACT_TYPE")
$([ -n "$ARTIFACT" ] && echo "**Artifact:** $ARTIFACT")
$([ -n "$SCHEMA" ] && echo "**Schema:** ~/deploy/dev-workflow/schemas/ — $SCHEMA")
$ROLE_FRAMING
EOF

echo "Launching $ROLE in $HARNESS (project: $(basename "$PROJECT_DIR"))"
[ -n "$ARTIFACT" ] && echo "  Artifact: $ARTIFACT"
echo ""

# Build harness-specific flags and prep
HARNESS_FLAGS=()
case "$HARNESS" in
    gemini)
        # Gemini sandbox restricts to project dir — whitelist the deploy tree
        HARNESS_FLAGS+=(--include-directories "$HOME/deploy/dev-workflow")
        ;;
    codex)
        # Codex reads the full filesystem (--sandbox read-only), so no context
        # copying needed — active-role.md already references ~/deploy/ paths.
        # Write AGENTS.md to project root to direct the model to active-role.md.
        if [ -f "$PROJECT_DIR/AGENTS.md" ]; then
            cp "$PROJECT_DIR/AGENTS.md" "$PROJECT_DIR/.workflow/AGENTS.md.bak"
        fi
        cp "$DEPLOY_DIR/harness/AGENTS.md" "$PROJECT_DIR/AGENTS.md"
        ;;
esac

# Launch via role script
export HARNESS
exec "$HOME/bin/role" workflow "$PROJECT_DIR" "${HARNESS_FLAGS[@]}" "$@"
