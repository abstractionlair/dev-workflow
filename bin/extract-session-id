#!/bin/bash
# Extract session/thread ID from CLI JSON output.
#
# Usage:
#   extract-session-id codex < output.jsonl
#   extract-session-id claude < output.json
#   extract-session-id gemini < output.json
#   some_command | extract-session-id codex
#
# Exits non-zero if no session ID found.

set -e

if [ -z "$1" ]; then
    echo "Usage: extract-session-id <codex|claude|gemini> < output" >&2
    exit 1
fi

CLI="$1"
INPUT=$(cat)

case "$CLI" in
    codex)
        # Codex JSONL: first line has {"type":"thread.started","thread_id":"<uuid>"}
        echo "$INPUT" | head -1 | python3 -c "
import json, sys
line = sys.stdin.read().strip()
obj = json.loads(line)
tid = obj.get('thread_id', '')
if not tid:
    print('Error: no thread_id in codex output', file=sys.stderr)
    sys.exit(1)
print(tid)
"
        ;;
    claude)
        # Claude JSON: {"session_id": "..."}
        echo "$INPUT" | python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
sid = data.get('session_id', '')
if not sid:
    print('Error: no session_id in claude output', file=sys.stderr)
    sys.exit(1)
print(sid)
"
        ;;
    gemini)
        # Gemini JSON: {"session_id": "..."}
        echo "$INPUT" | python3 -c "
import json, sys
data = json.loads(sys.stdin.read())
sid = data.get('session_id', '')
if not sid:
    print('Error: no session_id in gemini output', file=sys.stderr)
    sys.exit(1)
print(sid)
"
        ;;
    *)
        echo "Error: unknown CLI '$CLI'. Supported: codex, claude, gemini" >&2
        exit 1
        ;;
esac
