        "roadmap": "gemini-3.1-pro-preview",
        "spec": "gemini-3.1-pro-preview",
        "skeleton": "opencode/gpt-5.4",
        "tests": "opencode/gpt-5.4",
        "implementation": "opencode/gpt-5.4"
